---
import BaseLayout from "../../layouts/BaseLayout.astro";

const banks = [
  { title: "DSA (25 Problems)", desc: "Two Sum, LRU Cache, Merge Intervals, LIS, Trie full solutions with complexities", href: "/questions/dsa", count: 25, icon: "🧮" },
  { title: "C++ Coding & Output", desc: "Virtual dispatch, object slicing, move semantics, RAII tricky output questions", href: "/questions/cpp", count: 30, icon: "⚙️" },
  { title: "Python Coding", desc: "Generators, decorators, async/await, GIL Pythonic interview challenges", href: "/questions/python", count: 25, icon: "🐍" },
  { title: "Go Coding", desc: "Goroutines, channels, interfaces, context propagation", href: "/questions/golang", count: 20, icon: "🔵" },
  { title: "Java Coding", desc: "Concurrency, streams, generics, memory model questions", href: "/questions/java", count: 25, icon: "☕" },
  { title: "LLD Problems (25 Designs)", desc: "Parking lot, elevator, chess, pub/sub full class designs", href: "/questions/lld", count: 25, icon: "🏗️" },
  { title: "HLD System Design", desc: "URL shortener, chat system, video streaming complete architectures", href: "/questions/hld", count: 25, icon: "🌐" },
  { title: "CI/CD & DevOps", desc: "Pipeline scripts, Docker, K8s manifests, Terraform modules", href: "/questions/cicd", count: 25, icon: "🚀" },
  { title: "Architecture & Trade-offs", desc: "CAP theorem scenarios, consistency vs availability, design decisions", href: "/questions/architecture", count: 25, icon: "📐" },
];
---

<BaseLayout title="Question Banks" description="250+ interview questions across DSA, system design, and language-specific coding challenges">
  <section class="max-w-5xl mx-auto px-6 py-16">
    <header class="mb-12">
      <h1 class="text-4xl font-bold text-gray-900 dark:text-white mb-4">Question Banks</h1>
      <p class="text-lg text-gray-600 dark:text-gray-400">
        250+ curated problems with complete solutions, scoring guides, and follow-up questions. Use as an interviewer to select problems or as a candidate to practice.
      </p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
      {banks.map((b) => (
        <a href={b.href} class="glass rounded-xl p-5 card-hover group">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">{b.icon}</span>
            <span class="text-xs font-mono px-2 py-0.5 rounded bg-brand-100 dark:bg-brand-900/40 text-brand-700 dark:text-brand-300">
              {b.count} problems
            </span>
          </div>
          <h3 class="font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors mb-1">
            {b.title}
          </h3>
          <p class="text-sm text-gray-600 dark:text-gray-400">{b.desc}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
