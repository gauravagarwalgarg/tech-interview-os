---
import BaseLayout from "./BaseLayout.astro";
import Sidebar from "../components/Sidebar.astro";
import TableOfContents from "../components/TableOfContents.astro";

export interface Props {
  title: string;
  description?: string;
  section?: string;
  headings?: { depth: number; slug: string; text: string }[];
}

const { title, description, section, headings = [] } = Astro.props;
---

<BaseLayout title={title} description={description}>
  <div class="max-w-[1600px] mx-auto flex">
    <Sidebar currentSection={section} />

    <article class="flex-1 min-w-0 px-6 py-8 lg:px-12 lg:py-12">
      <header class="mb-8">
        {section && (
          <p class="text-sm font-medium text-brand-600 dark:text-brand-400 mb-2 uppercase tracking-wider">
            {section}
          </p>
        )}
        <h1 class="text-4xl font-bold text-gray-900 dark:text-white">
          {title}
        </h1>
        {description && (
          <p class="mt-3 text-lg text-gray-600 dark:text-gray-400">
            {description}
          </p>
        )}
      </header>

      <div class="prose-content">
        <slot />
      </div>
    </article>

    {headings.length > 0 && (
      <TableOfContents headings={headings} />
    )}
  </div>
</BaseLayout>
