---
export interface Props {
  currentSection?: string;
}

const { currentSection } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const navigation = [
  {
    title: "Getting Started",
    items: [
      { label: "Overview", href: `${base}/` },
      { label: "Interview Flow", href: `${base}/rounds` },
      { label: "Profiles", href: `${base}/profiles` },
    ],
  },
  {
    title: "Rounds",
    items: [
      { label: "Coding & DSA", href: `${base}/rounds/coding` },
      { label: "Low-Level Design", href: `${base}/rounds/lld` },
      { label: "High-Level Design", href: `${base}/rounds/hld` },
      { label: "Infra & CI/CD", href: `${base}/rounds/infra` },
      { label: "Behavioral", href: `${base}/rounds/behavioral` },
    ],
  },
  {
    title: "Question Banks",
    items: [
      { label: "DSA (25 Problems)", href: `${base}/questions/dsa` },
      { label: "C++ Coding", href: `${base}/questions/cpp` },
      { label: "Python Coding", href: `${base}/questions/python` },
      { label: "Go Coding", href: `${base}/questions/golang` },
      { label: "Java Coding", href: `${base}/questions/java` },
      { label: "LLD Problems", href: `${base}/questions/lld` },
      { label: "HLD Systems", href: `${base}/questions/hld` },
      { label: "CI/CD & DevOps", href: `${base}/questions/cicd` },
    ],
  },
  {
    title: "Domain Deep Dives",
    items: [
      { label: "Backend & Cloud", href: `${base}/domains/backend` },
      { label: "Silicon & Embedded", href: `${base}/domains/silicon` },
      { label: "Frontend", href: `${base}/domains/frontend` },
      { label: "Networking & OS", href: `${base}/domains/networking` },
      { label: "C++ Architecture", href: `${base}/domains/cpp` },
      { label: "Yocto & Linux", href: `${base}/domains/yocto` },
    ],
  },
  {
    title: "Rubrics & Evaluation",
    items: [
      { label: "Level Calibration", href: `${base}/rubrics/levels` },
      { label: "Coding Rubric", href: `${base}/rubrics/coding` },
      { label: "LLD Rubric", href: `${base}/rubrics/lld` },
      { label: "HLD Rubric", href: `${base}/rubrics/hld` },
      { label: "Feedback Template", href: `${base}/rubrics/feedback` },
    ],
  },
];
---

<aside class="hidden lg:block w-72 shrink-0 border-r border-gray-200 dark:border-gray-700/50 h-[calc(100vh-4rem)] sticky top-16 overflow-y-auto py-6 px-4">
  <nav class="space-y-6">
    {navigation.map((group) => (
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 mb-2 px-3">
          {group.title}
        </h3>
        <ul class="space-y-0.5">
          {group.items.map((item) => (
            <li>
              <a
                href={item.href}
                class:list={[
                  "block px-3 py-1.5 rounded-md text-sm transition-colors",
                  currentSection === item.label
                    ? "bg-brand-100 dark:bg-brand-950/40 text-brand-700 dark:text-brand-300 font-medium"
                    : "text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white hover:bg-gray-100 dark:hover:bg-gray-800/50",
                ]}
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    ))}
  </nav>
</aside>
